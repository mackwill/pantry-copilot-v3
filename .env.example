# Postgres (dev via infra/podman/compose.yaml)
DATABASE_URL=postgres://pantry:pantry@localhost:5432/pantry
# Auth (M1) — secret must be ≥32 chars
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
# Dev/e2e only — rejected when NODE_ENV=production
AUTH_DEV_MAGIC_LINK=false
# AI service (M3) — shared bearer token between api ↔ ai, must be ≥32 chars
AI_SERVICE_TOKEN=
# Provider selection: mock (default, no keys) | anthropic | openai
DEFAULT_AI_PROVIDER=mock
DEFAULT_AI_MODEL=claude-sonnet-4-6
# Only needed when DEFAULT_AI_PROVIDER is anthropic/openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
